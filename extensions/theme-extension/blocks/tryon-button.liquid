{{ 'tryon-widget.css' | asset_url | stylesheet_tag }}

<button
  id="tryon-btn-{{ product.id | split: '/' | last }}"
  class="tryon-trigger-btn {{ block.settings.button_classes }}"
  data-tryon-product-id="{{ product.id | split: '/' | last }}"
  data-tryon-shop="{{ shop.permanent_domain }}"
  data-tryon-color="{{ block.settings.button_color }}"
  data-tryon-country="{{ localization.country.iso_code }}"
  data-tryon-model-man="{{ 'model-man.jpg' | asset_url }}"
  data-tryon-model-woman="{{ 'model-woman.jpg' | asset_url }}"
  data-tryon-model-man-2="{{ 'model-man.png' | asset_url }}"
  data-tryon-model-woman-2="{{ 'model-woman.png' | asset_url }}"
  data-tryon-product-image="{{ product.featured_image | image_url: width: 1024 }}"
  data-tryon-product-title="{{ product.title | escape }}"
  data-tryon-product-type="{{ product.type | escape }}"
  style="
    display: none;
    --tryon-color: {{ block.settings.button_color }};
    background: var(--tryon-color);
    color: #fff;
    border: none;
    cursor: pointer;
    text-align: center;
  "
>
  {{ block.settings.button_text }}
</button>

<script>
  (function () {
    var productId = "{{ product.id | split: '/' | last }}";
    var btn = document.getElementById("tryon-btn-" + productId);
    var loaded = false;

    // Copy computed dimensions from the Add to Cart / Buy Now button so
    // the Try It On button is pixel-identical regardless of the theme.
    function mirrorButtonDimensions(skipWidth) {
      // Covers every major Shopify theme's product-form submit button
      var atcBtn = document.querySelector(
        'form[action*="/cart/add"] button[type="submit"]:not(#' + btn.id + '),' +
        'form[action="/cart/add"] button[type="submit"]:not(#' + btn.id + '),' +
        '[name="add"]:not(#' + btn.id + ')'
      );
      if (!atcBtn) return;
      var cs = window.getComputedStyle(atcBtn);
      if (!skipWidth) {
        btn.style.width         = cs.width;
      }
      btn.style.height        = cs.height;
      btn.style.minHeight     = cs.minHeight;
      btn.style.fontSize      = cs.fontSize;
      btn.style.fontWeight    = cs.fontWeight;
      btn.style.lineHeight    = cs.lineHeight;
      btn.style.letterSpacing = cs.letterSpacing;
      btn.style.textTransform = cs.textTransform;
      btn.style.paddingTop    = cs.paddingTop;
      btn.style.paddingBottom = cs.paddingBottom;
      btn.style.paddingLeft   = cs.paddingLeft;
      btn.style.paddingRight  = cs.paddingRight;
      btn.style.fontFamily    = cs.fontFamily;
      btn.style.textAlign     = cs.textAlign;
      btn.style.justifyContent = cs.justifyContent;
      btn.style.alignItems    = cs.alignItems;
    }

    function applyConfig(data) {
      // Apply merchant dashboard settings to the button
      if (data.buttonText) {
        btn.textContent = data.buttonText;
      }
      if (data.buttonColor) {
        btn.style.background = data.buttonColor;
        btn.style.setProperty('--tryon-color', data.buttonColor);
        btn.setAttribute('data-tryon-color', data.buttonColor);
      }
      if (data.borderRadius !== undefined) {
        btn.style.borderRadius = data.borderRadius + 'px';
      }
      if (data.fullWidth === false) {
        // Auto-size: don't mirror the ATC button width
        btn.style.width = 'auto';
        btn.style.minWidth = '160px';
      }

      // For floating-corner: detach from current position and fix to viewport
      if (data.buttonPosition === 'floating-corner') {
        document.body.appendChild(btn);
        btn.style.position = 'fixed';
        btn.style.bottom = '24px';
        btn.style.right = '24px';
        btn.style.zIndex = '9999';
        btn.style.width = 'auto';
        btn.style.minWidth = '0';
        btn.style.boxShadow = '0 4px 16px rgba(0,0,0,0.25)';
        btn.style.padding = '10px 18px';
      }
      // above/below: block stays where the merchant placed it in the theme editor
    }

    function showButton(skipWidth) {
      btn.style.display = "";
      // Mirror after the button is in the layout so getComputedStyle is accurate
      requestAnimationFrame(function () { mirrorButtonDimensions(skipWidth); });
      // Re-mirror whenever the viewport resizes so max-width breakpoints stay in sync
      if (window.ResizeObserver) {
        var ro = new ResizeObserver(function () { mirrorButtonDimensions(skipWidth); });
        ro.observe(document.documentElement);
      }
    }

    // Check if try-on is enabled for this product via App Proxy.
    // The response also includes merchant config (buttonText, buttonColor, etc.)
    // so we apply those settings dynamically — no theme editor changes needed.
    fetch("/apps/try-on?productId=" + productId + "&_t=" + Date.now())
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.enabled) {
          applyConfig(data);
          showButton(data.fullWidth === false);
        }
      })
      .catch(function () {
        // Fetch failed — show button with block schema defaults so it's never invisible
        showButton(false);
      });

    btn.addEventListener("click", function () {
      if (!loaded) {
        loaded = true;
        var s = document.createElement("script");
        s.src = {{ 'tryon-widget.js' | asset_url | json }};
        document.head.appendChild(s);
      }
    });
  }());
</script>

{% schema %}
{
  "name": "Try It On Button",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text (fallback)",
      "default": "Try It On",
      "info": "Used if the app dashboard settings can't be loaded. Set your primary text in the Slidez dashboard."
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color (fallback)",
      "default": "#000000",
      "info": "Used if the app dashboard settings can't be loaded."
    },
    {
      "type": "text",
      "id": "button_classes",
      "label": "Theme button CSS classes",
      "info": "Paste your theme's button class(es) to match Add to Cart sizing — e.g. btn btn--full-width (Debut) or button button--full-width (Dawn)"
    }
  ]
}
{% endschema %}
